{
  "name": "obsidian-github-image-uploader",
  "version": "1.0.0",
  "description": "Upload images to GitHub when pasting in Obsidian. Choose between cloud hosting or local storage.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "image", "github", "upload"],
  "author": "Xuan",
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.26.3",
    "@types/node": "^22.0.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.21.5",
    "obsidian": "latest",
    "tslib": "^2.6.2",
    "typescript": "^5.5.3"
  }
}
