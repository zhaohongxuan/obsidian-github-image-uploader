{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "lib": ["DOM", "ES5", "ES6", "ES7", "ES2017"],
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts"]
}
