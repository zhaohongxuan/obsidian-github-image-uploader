{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowSyntheticDefaultImports": true,
    "importHelpers": true,
    "lib": ["DOM", "ES5", "ES6", "ES7"],
    "moduleResolution": "node"
  },
  "include": ["**/*.ts"]
}
